{
  "name": "@browser-annotations/workspace",
  "version": "1.6.2",
  "private": true,
  "keywords": [
    "browser-annotations"
  ],
  "scripts": {
    "format": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "check:format": "pnpm run format",
    "check:lint": "pnpm run lint",
    "check:types": "pnpm -r --parallel run check:types",
    "check": "pnpm run check:lint && pnpm run check:format && pnpm run check:types",
    "fix": "pnpm run lint:fix && pnpm run format:fix && pnpm run check",
    "version": "bash scripts/version.sh"
  },
  "devDependencies": {
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0"
  },
  "packageManager": "pnpm@10.18.3",
  "pi": {
    "extensions": [
      "./packages/pi/src/index.ts"
    ]
  }
}
