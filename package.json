{
  "name": "@browser-annotations/workspace",
  "private": true,
  "scripts": {
    "format": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "check:format": "bun run format",
    "check:lint": "bun run lint",
    "check:types": "pnpm -r --parallel run check:types",
    "check": "bun run check:lint && bun run check:format && bun run check:types",
    "fix": "bun run lint:fix && bun run format:fix && bun run check"
  },
  "devDependencies": {
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0"
  },
  "packageManager": "pnpm@10.18.3"
}
