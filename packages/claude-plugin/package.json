{
  "name": "@browser-annotations/claude-plugin",
  "private": true,
  "description": "Receive browser annotations in Claude Code",
  "type": "module",
  "scripts": {
    "start": "bun install --production --no-summary && bun server.ts",
    "dev": "bun --hot server.ts",
    "dev:claude": "rm -rf ~/.claude/plugins/cache/browser-annotations && bunx kill-port ${BROWSER_ANNOTATIONS_PORT:-8765} && cd ../../ && claude --dangerously-skip-permissions --dangerously-load-development-channels plugin:browser-annotations@browser-annotations --debug",
    "check": "bun run check:types",
    "check:types": "tsgo -b ./tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@typescript/native-preview": "7.0.0-dev.20251207.1"
  },
  "engines": {
    "bun": "^1.3.9"
  }
}
