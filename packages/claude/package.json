{
  "name": "@browser-annotations/claude",
  "description": "Select an element, add feedback, and send it to Claude Code.",
  "type": "module",
  "scripts": {
    "dev": "rm -rf ~/.claude/plugins/cache/browser-annotations && cd ../../ && claude --dangerously-skip-permissions --dangerously-load-development-channels plugin:claude@browser-annotations --debug",
    "start": "bun install --production && bun src/index.ts",
    "check": "pnpm run check:types",
    "check:types": "tsgo -b ./tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20251207.1"
  },
  "engines": {
    "node": ">=24"
  }
}
